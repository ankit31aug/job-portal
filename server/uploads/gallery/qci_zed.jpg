<script>
    var allsrc = Array.from(document.querySelectorAll('.swiper-slide a figure .swiper-slide-image')).map(function(el) {
            return el.getAttribute('src');
        });
        if (allsrc.length > 0) {
            document.querySelectorAll('.elementor-image-carousel .swiper-slide a figure .swiper-slide-image').forEach(function(el) {
                var src = el.getAttribute('src');
                var parentLink = el.closest('a');
                if (src === 'https://qcin.org/wp-content/uploads/2024/09/GWOu_nKbMAA72Ik.jpeg') {
                    parentLink.setAttribute('href', 'https://pledge.mygov.in/qualitybharat/');
                }
                else {
                    parentLink.setAttribute('href', 'javascript:void(0)');
                }
            });
        }
</script>
