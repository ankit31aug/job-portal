  <script>
(function(){
  document.addEventListener('click', function(e){
    const a = e.target.closest('a');
    if(!a) return;
    if(a.target !== '_blank') return; // only when set to open in new tab
    const href = a.href;
    if(!href) return;

    try {
      const url = new URL(href, location.href);
      if(url.hostname === location.hostname) return; // skip same-site
    } catch (err) {
      return; // invalid URL, ignore
    }

    e.preventDefault();
    const msg = 'You are about to open an external website in a new tab. Continue?';
    if(confirm(msg)){
      const newWin = window.open();
      if (newWin) {
        newWin.opener = null;
        newWin.location = href;
      } else {
        window.open(href, '_blank');
      }
    }
  });
})();
</script>
<!-- same hostname but want to show alert  -->
<script>
(function(){
  function openInNewTab(url) {
    // try to open a blank window first (popup should be allowed since we're in a user event)
    var w = window.open('', '_blank');
    if (w) {
      try { w.opener = null; } catch(e) {}
      w.location = url;
    } else {
      // fallback
      window.open(url, '_blank');
    }
  }

  document.addEventListener('click', function(e){
    // get the element clicked
    var clicked = e.target;

    // find nearest element that has our marker class (could be wrapper or the link itself)
    var marker = clicked.closest('.show-alert');

    // find the nearest anchor (if any)
    var anchor = clicked.closest('a');

    // if no marker on clicked element, check if anchor itself has show-alert
    if(!marker && anchor && anchor.classList.contains('show-alert')) {
      marker = anchor;
    }

    // if we have a marker but no anchor, try to find an anchor inside the marker
    if(marker && !anchor) {
      anchor = marker.querySelector('a');
    }

    // If there is no marker anywhere, do nothing (we only act on marked items)
    if(!marker) return;

    // extract href (prefer anchor href; if anchor missing, try data-href on marker)
    var href = (anchor && anchor.getAttribute('href')) || marker.getAttribute('data-href') || marker.dataset.href;

    if(!href || href === '#' || href.indexOf('javascript:') === 0) {
      // nothing meaningful to open
      return;
    }

    // OPTIONAL: If you only want to warn for new-tab links, uncomment:
    // if (anchor && anchor.target !== '_blank') return;

    // prevent normal navigation and show confirmation
    e.preventDefault();
    e.stopPropagation();

    var message = marker.dataset.confirmMsg || 'You are about to open this link in a new tab. Continue?';
    if (confirm(message)) {
      openInNewTab(href);
    }
    // else do nothing (user cancelled)
  }, false);
})();
</script>


			<script>
				const lazyloadRunObserver = () => {
					const lazyloadBackgrounds = document.querySelectorAll( `.e-con.e-parent:not(.e-lazyloaded)` );
					const lazyloadBackgroundObserver = new IntersectionObserver( ( entries ) => {
						entries.forEach( ( entry ) => {
							if ( entry.isIntersecting ) {
								let lazyloadBackground = entry.target;
								if( lazyloadBackground ) {
									lazyloadBackground.classList.add( 'e-lazyloaded' );
								}
								lazyloadBackgroundObserver.unobserve( entry.target );
							}
						});
					}, { rootMargin: '200px 0px 200px 0px' } );
					lazyloadBackgrounds.forEach( ( lazyloadBackground ) => {
						lazyloadBackgroundObserver.observe( lazyloadBackground );
					} );
				};
				const events = [
					'DOMContentLoaded',
					'elementor/lazyload/observe',
				];
				events.forEach( ( event ) => {
					document.addEventListener( event, lazyloadRunObserver );
				} );
			</script>
