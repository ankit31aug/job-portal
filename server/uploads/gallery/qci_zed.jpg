                <h3 class="widget dekoline dekoline_small">Visitor Count</h3><div class="textwidget custom-html-widget"><div id="visitorCount"></div>
<script type="application/javascript">
jQuery(document).ready(function(){
 jQuery.post("https://qualitysetu.qci.org.in/api/visitors",
  {
    site: "qci",
    ip: "123"
  },
  function(data, status){
	 
	counter=pad (data.count,10); 
	innerHtml='';
	 for (var i = 0; i < 10; i++) {
		 innerHtml=innerHtml+'<div class="counter-item">'+counter[i]+'</div>';
	 }
       
    jQuery('#visitorCount').html(innerHtml);
  });
});
function pad (str, max) {
  str = str.toString();
  return str.length < max ? pad("0" + str, max) : str;
}
	
</script>

    <style>
        #visitorCount {
            background: #f8a421;
            display: flex;
            float: left;
            padding: 2px;


        }

        .counter-item {
            background: linear-gradient(180deg, rgba(120, 125, 133, 1) 50%, rgba(0, 0, 0, 1) 50%);
            padding: 5px;
            color: #fff;
            font-size: 20px;
            margin: 2px;
            border-radius: 3px;
        }
			
    </style>
